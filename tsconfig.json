{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "strict": true,
    "lib": ["DOM", "ES2022"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["main.ts", "src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules"]
}
